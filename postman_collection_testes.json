      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"nome\": \"Minha Loja\",\n  \"cnpj\": \"12345678000100\",\n  \"email\": \"loja@email.com\",\n  \"senha\": \"senha123\",\n  \"celular\": \"11999999999\"\n}"
        },
        "url": {
          "raw": "http://localhost:5000/api/sellers",
          "protocol": "http",
          "host": ["localhost"],
          "port": "5000",
          "path": ["api", "sellers"]
        }
      }
    },
    {
