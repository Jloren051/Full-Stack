{
  "info": {
    "name": "Full-Stack API Tests",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Register Seller",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"nome\": \"Test Seller\",\n  \"cnpj\": \"12345678000123\",\n  \"email\": \"test@example.com\",\n  \"senha\": \"password123\",\n  \"celular\": \"+551198930829\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/sellers",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "sellers"
          ]
        }
      }
    },
    {
      "name": "Activate Seller",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"celular\": \"+551198930829\",\n  \"codigo\": \"{{activation_code}}\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/sellers/activate",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "sellers",
            "activate"
          ]
        }
      }
    },
    {
      "name": "Login Seller",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"test@example.com\",\n  \"senha\": \"password123\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/sellers/login",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "sellers",
            "login"
          ]
        }
      }
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:5000"
    },
    {
      "key": "activation_code",
      "value": ""
    }
  ]
}